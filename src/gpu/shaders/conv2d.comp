#version 450

// Vulkan (GLSL). NCHW input, OIHW (well, O/groups-per-output, "OCgKHKW")
// weights, explicit padding/stride/dilation/groups — matches the CPU
// backend's evalConv2d (src/cpu/ops.cpp) exactly, including that conv2d
// itself carries no bias (bias is fused into a separate add() at import
// time — see CLAUDE.md's ONNX-import notes). One workgroup per output
// element (ow, oh, n*O+o) — dispatchX=outW, dispatchY=outH,
// dispatchZ=N*O — with the single active thread doing the full
// Cg*KH*KW accumulation itself, same naive/no-tiling model as the CPU
// reference kernel (this round proves correctness, not speed, same as
// every other op here). Coordinate math (`ih`/`iw`) is done in *signed*
// integers — padding makes early output positions read from a
// before-the-start input coordinate, which must underflow to negative,
// not wrap around as an unsigned value.
layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer XBuf { float data[]; } xBuf;
layout(std430, binding = 1) readonly buffer WBuf { float data[]; } wBuf;
layout(std430, binding = 2) buffer OutBuf { float data[]; } outputBuf;
layout(binding = 3) uniform Params
{
    uint O, C, H, W, Cg, KH, KW, outH, outW;
    uint strideX, strideY, dilationX, dilationY, paddingLeft, paddingTop;
    uint inPerGroup, outPerGroup;
} params;

void main()
{
    // No bounds check needed — dispatchX/Y/Z are set to exactly
    // outW/outH/(N*O) in gpu_backend.cpp, so no over-dispatch is possible
    // here, same reasoning as layernorm.comp's row dispatch.
    uint ow = gl_WorkGroupID.x;
    uint oh = gl_WorkGroupID.y;
    uint no = gl_WorkGroupID.z;
    uint n = no / params.O;
    uint o = no % params.O;
    uint group = o / params.outPerGroup;
    uint inChannelBase = group * params.inPerGroup;

    float sum = 0.0;
    for (uint ci = 0u; ci < params.Cg; ci++)
    {
        uint c = inChannelBase + ci;
        for (uint kh = 0u; kh < params.KH; kh++)
        {
            int ih = int(oh * params.strideY) - int(params.paddingTop) + int(kh * params.dilationY);
            if (ih < 0 || ih >= int(params.H))
                continue;
            for (uint kw = 0u; kw < params.KW; kw++)
            {
                int iw = int(ow * params.strideX) - int(params.paddingLeft) + int(kw * params.dilationX);
                if (iw < 0 || iw >= int(params.W))
                    continue;
                float xv = xBuf.data[((n * params.C + c) * params.H + uint(ih)) * params.W + uint(iw)];
                float wv = wBuf.data[((o * params.Cg + ci) * params.KH + kh) * params.KW + kw];
                sum += xv * wv;
            }
        }
    }
    outputBuf.data[(no * params.outH + oh) * params.outW + ow] = sum;
}
